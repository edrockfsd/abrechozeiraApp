{
  "openapi": "3.0.1",
  "info": {
    "title": "AbiaApp.API",
    "version": "1.0"
  },
  "paths": {
    "/api/Agente/origens": {
      "get": {
        "tags": [
          "Agente"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Agente/cadastrar": {
      "post": {
        "tags": [
          "Agente"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PedidoCadastro"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/PedidoCadastro"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/PedidoCadastro"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Agente/excluir/{id}": {
      "delete": {
        "tags": [
          "Agente"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Agente/excluir/ultimo": {
      "delete": {
        "tags": [
          "Agente"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Agente/testar-modelos": {
      "get": {
        "tags": [
          "Agente"
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              },
              "application/json": {
                "schema": {
                  "type": "string"
                }
              },
              "text/json": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/api/Auth/login": {
      "post": {
        "tags": [
          "Auth"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "LoginRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "nullable": true
          },
          "password": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "PedidoCadastro": {
        "type": "object",
        "properties": {
          "textoUsuario": {
            "type": "string",
            "nullable": true
          },
          "origemFixa": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
  }
}